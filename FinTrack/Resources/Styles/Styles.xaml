<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="#0B0D11"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="#E8EAF0"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="#E8EAF0"/>
        <Setter Property="PlaceholderColor" Value="#5A6070"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="TextColor" Value="Black"/>
        <Setter Property="BackgroundColor" Value="#00E5A0"/>
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="#13161D"/>
        <Setter Property="Shell.ForegroundColor" Value="#E8EAF0"/>
        <Setter Property="Shell.TitleColor" Value="#E8EAF0"/>
        <Setter Property="Shell.NavBarHasShadow" Value="False"/>
        <Setter Property="Shell.TabBarBackgroundColor" Value="#13161D"/>
    </Style>

</ResourceDictionary>